# ---- Google Gemini / LLM ---------------------------------------------------
# Get a free key at https://aistudio.google.com/apikey  --  NEVER commit it.
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Gemini model used by the LangChain analysis layer (free-tier friendly).
LLM_MODEL=gemini-2.5-flash

# ---- API security ----------------------------------------------------------
# Required in the "X-API-Key" header for write operations (e.g. /import).
API_KEY=dev-secret-key

# ---- Database --------------------------------------------------------------
# Matches the "db" service in docker-compose.yml.
DATABASE_URL=postgresql+psycopg2://asm:asm@db:5432/asm

# ---- Behaviour tuning ------------------------------------------------------
# A certificate within this many days of expiry is "expiring soon".
EXPIRING_SOON_DAYS=30
# Default tenant used when a request does not specify an organization.
DEFAULT_ORG_ID=default
